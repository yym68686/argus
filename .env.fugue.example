# Copy this file to .env.fugue, fill the values, then deploy with:
# fugue --tenant <tenant> --project <project-name> deploy github yym68686/argus --env-file .env.fugue
#
# ARGUS_FUGUE_PROJECT_ID must be the id of the existing project selected by --project.
# The bundled fugue.yaml resolves session images from the "runtime" compose service,
# so you do not need to pre-publish ARGUS_FUGUE_RUNTIME_IMAGE.

ARGUS_FUGUE_BASE_URL=https://api.fugue.pro
ARGUS_FUGUE_TOKEN=
ARGUS_FUGUE_PROJECT_ID=
ARGUS_FUGUE_RUNTIME_ID=runtime_managed_shared

# Gateway auth / session-derived auth.
ARGUS_TOKEN=
ARGUS_MCP_TOKEN=
ARGUS_NODE_TOKEN=
ARGUS_OPENAI_TOKEN=

# Default OpenAI key for the built-in gateway channel.
OPENAI_API_KEY=

# Required if you keep the telegram-bot service in fugue.yaml.
TELEGRAM_BOT_TOKEN=
TELEGRAM_DRAFT_STREAMING=auto

# Optional overrides.
# ARGUS_RUNTIME_CMD=codex app-server
# ARGUS_FUGUE_WORKSPACE_STORAGE_SIZE=10Gi
# ARGUS_FUGUE_WORKSPACE_STORAGE_CLASS=
