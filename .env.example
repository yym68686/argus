# Copy to .env and edit as needed.
#
# NOTE:
# - `ARGUS_HOME_HOST_PATH` / `ARGUS_WORKSPACE_HOST_PATH` MUST be absolute host paths.
# - `ARGUS_TOKEN` is a gateway token (not an API key). Use a random string.

# Used in docs / clients (not required for docker compose itself).
HOST=127.0.0.1

# Optional: require auth for WebSocket `/ws`.
ARGUS_TOKEN=change-me

# Optional: use separate tokens per surface (when unset, falls back to ARGUS_TOKEN).
# ARGUS_NODE_TOKEN=change-me
# ARGUS_MCP_TOKEN=change-me

# Optional: built-in `gateway` API channel (recommended if you want new users to work out of the box).
# These secrets stay on the gateway; runtime containers only receive derived proxy tokens.
# `ARGUS_OPENAI_RESPONSES_UPSTREAM_URL` is used by the built-in `gateway` channel only.
# `ARGUS_OPENAI_TOKEN` controls per-session auth for `/openai/v1/responses`; when unset it falls back to `ARGUS_TOKEN`.
# OPENAI_API_KEY=sk-...
# ARGUS_OPENAI_API_KEY=sk-...
# ARGUS_OPENAI_RESPONSES_UPSTREAM_URL="https://api.openai.com/v1/responses"
# ARGUS_OPENAI_TOKEN=change-me

# Optional (web UI): preset the WebSocket URL shown on first load.
# NOTE: This is baked into the web build output; rebuild `web` after changing it.
# NEXT_PUBLIC_ARGUS_WS_URL="ws://127.0.0.1:8080/ws?token=change-me"

# Host paths for gateway state and local workspace mirrors.
# Default (when unset): `${HOME}/.argus` (see `docker-compose.yml`).
# ARGUS_HOME_HOST_PATH=/srv/argus
# Optional (advanced): base directory for auto-created `/ws` session workspaces (absolute path).
# When unset, generic sessions use `${ARGUS_HOME_HOST_PATH}/workspaces/sess-<sessionId>`.
# ARGUS_WORKSPACE_HOST_PATH=/srv/argus/workspaces

# Runtime provision mode:
# - auto: prefer Fugue when complete Fugue config is present, then Docker when a local endpoint is available, else static
# - docker: auto-create local Docker containers (default in docker-compose.yml)
# - fugue: auto-create one Fugue app per managed session
# - static: connect to pre-existing app-servers
# ARGUS_PROVISION_MODE=auto
#
# Fugue mode example:
# ARGUS_PROVISION_MODE=fugue
# ARGUS_FUGUE_BASE_URL="https://fugue.example.com"
# ARGUS_FUGUE_TOKEN=change-me
# ARGUS_FUGUE_PROJECT_ID=proj_123
# ARGUS_FUGUE_RUNTIME_IMAGE=ghcr.io/example/argus-runtime:latest
# ARGUS_FUGUE_RUNTIME_ID=runtime_managed_shared
# ARGUS_GATEWAY_INTERNAL_HOST=argus-gateway.default.svc.cluster.local
# ARGUS_FUGUE_WORKSPACE_STORAGE_SIZE=10Gi
# ARGUS_FUGUE_WORKSPACE_STORAGE_CLASS=
# ARGUS_FUGUE_SERVICE_PORT=7777
# ARGUS_FUGUE_APP_NAME_PREFIX=argus-session

# Runtime install + start (defaults below are for the current Codex CLI).
ARGUS_RUNTIME_INSTALL_CMD="npm i -g @openai/codex"
ARGUS_RUNTIME_CMD="codex app-server"

# Optional: resource limits for dynamically spawned runtime session containers (recommended on small servers).
# ARGUS_RUNTIME_CPUS=0.8
# ARGUS_RUNTIME_MEM_LIMIT=768m
# Optional: set equal to mem limit to disable swap.
# ARGUS_RUNTIME_MEMSWAP_LIMIT=768m
# Optional: cap process count inside the runtime container.
# ARGUS_RUNTIME_PIDS_LIMIT=512

# Optional: allow larger JSONL messages from the runtime (e.g. long tool output).
# If you see `Separator is not found, and chunk exceed the limit`, increase this.
# Default: 128MB (134217728).
# ARGUS_JSONL_LINE_LIMIT_BYTES=134217728

# Node Host (run on your Mac, connects to the gateway):
# NOTE:
# - When auth is configured, /nodes/ws requires a derived token: argus-node-v1.<sessionId>.<sig>
# ARGUS_NODE_WS_URL="ws://127.0.0.1:8080/nodes/ws?token=change-me"
#
# Optional (node-host): websocket retry/keepalive tuning.
# ARGUS_NODE_HANDSHAKE_TIMEOUT_MS=15000
# ARGUS_NODE_CONNECT_TIMEOUT_MS=20000
# ARGUS_NODE_RECONNECT_DELAY_MS=1000
# ARGUS_NODE_RECONNECT_DELAY_MAX_MS=30000
# ARGUS_NODE_RECONNECT_JITTER_PCT=0.2
# ARGUS_NODE_PING_INTERVAL_MS=30000
# ARGUS_NODE_PONG_TIMEOUT_MS=10000

# Optional: override Docker socket path (macOS OrbStack example)
# DOCKER_SOCK="$HOME/.orbstack/run/docker.sock"

# Orphan runtime GC on gateway startup.
# "orphan" = a managed runtime (docker container or Fugue app) whose `sessionId`
# is not referenced by `${ARGUS_HOME_HOST_PATH}/gateway/state.json`.
#
# Values:
# - (unset): delete (default)
# - off / 0 / false: disabled
# - dry-run: log only
# - 1 / true / yes: delete
# ARGUS_GC_DELETE_ORPHAN_RUNTIMES=off

# Telegram Bot (optional; enable via `docker compose --profile tg ...`)
# NOTE: when set, the gateway can also deliver outbound messages via Telegram.
# TELEGRAM_BOT_TOKEN=change-me
